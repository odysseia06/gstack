#!/usr/bin/env bash
# gstack-migrate-workspace — move OLD in-repo gstack artifacts to the AI workspace.
#
# Skills now write reports, generated docs, and ADRs to ~/.ai-workspace/<repo>/
# (resolved by gstack-slug as GSTACK_WORKSPACE_DIR). This one-shot, per-repo
# migration moves artifacts left behind by the OLD in-repo layout into that
# workspace and stops them being tracked in git. Run it once inside each repo
# that predates the change.
#
# Usage:
#   gstack-migrate-workspace                          # DRY-RUN: print the plan
#   gstack-migrate-workspace --apply                  # move reports + ADRs
#   gstack-migrate-workspace --apply --include-docs   # ALSO move Diataxis-named docs
#
# Auto-moved (unambiguous gstack artifacts) -> $GSTACK_WORKSPACE_DIR. Most preserve
# the repo-relative subpath; a few get relocated to a cleaner subdir:
#   - .gstack/{qa,benchmark,canary,security,deploy}-reports/   scratch reports
#   - .context/claude-session-id          -> sessions/claude-session-id
#   - .context/codex-session-id           -> sessions/codex-session-id
#   - .context/retros/                    -> retros/
#   - .gstack/wip-context-before-squash.md -> ship/wip-context-before-squash.md
#   - docs/adr/  and  src/*/docs/adr/                          ADRs
#
# Opt-in only (needs --include-docs): docs/ files named tutorial-* reference-*
#   howto-* how-to-* explanation-*. The name heuristic ALSO matches hand-written
#   docs — gstack itself names its real docs this way — so these are listed as
#   candidates and never moved without the explicit flag.
#
# Always left in the repo (and listed if present): every other docs/*.md,
#   CONTEXT.md, docs/agents/, .scratch/, README/CHANGELOG/etc.
#
# Git: tracked artifacts are `git rm -r --cached`'d and a pattern added to
#   .gitignore; the staged removal is LEFT for you to review, commit, and push
#   (this never commits or pushes for you). Untracked artifacts are just moved.
#   History keeps the old versions either way. Tracked items show as [TRACKED]
#   in the plan so you see what will disappear for other clones before --apply.
#
# Safe: never overwrites an existing workspace file (skips + warns). Idempotent.
set -euo pipefail

APPLY=0
INCLUDE_DOCS=0
for arg in "$@"; do
  case "$arg" in
    --apply)        APPLY=1 ;;
    --include-docs) INCLUDE_DOCS=1 ;;
    --dry-run)      APPLY=0 ;;
    *) echo "usage: gstack-migrate-workspace [--apply] [--include-docs]" >&2; exit 1 ;;
  esac
done

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/gstack-slug" 2>/dev/null)" || true
: "${REPO:?could not resolve repo name — run inside a repo}"
: "${GSTACK_WORKSPACE_DIR:?could not resolve workspace dir}"
DEST="$GSTACK_WORKSPACE_DIR"

IS_GIT=0
git rev-parse --is-inside-work-tree >/dev/null 2>&1 && IS_GIT=1

printf 'Repo:      %s\nWorkspace: %s\nMode:      %s\n\n' \
  "$REPO" "$DEST" "$([ "$APPLY" -eq 1 ] && echo APPLY || echo 'DRY-RUN (use --apply to execute)')"

declare -a IGN=()
n_move=0
n_skip=0

_tracked() { [ "$IS_GIT" -eq 1 ] && git ls-files --error-unmatch "$1" >/dev/null 2>&1; }

_diataxis_docs() {
  [ -d docs ] || return 0
  find docs -maxdepth 2 -type f \
    \( -name 'tutorial-*.md' -o -name 'reference-*.md' -o -name 'howto-*.md' \
       -o -name 'how-to-*.md' -o -name 'explanation-*.md' \) 2>/dev/null | sort
}

migrate() {            # migrate <src-rel> [gitignore-pattern] [explicit-dst-subpath]
  local rel="$1" pat="${2:-}" override="${3:-}"
  [ -e "$rel" ] || return 0
  local dst trk=untracked
  if [ -n "$override" ]; then
    dst="$DEST/$override"
  else
    dst="$DEST/$rel"
  fi
  _tracked "$rel" && trk=TRACKED
  if [ -e "$dst" ]; then
    printf '  SKIP  %-44s (workspace already has it)\n' "$rel"
    n_skip=$((n_skip + 1)); return 0
  fi
  printf '  MOVE  %-44s -> %s   [%s]\n' "$rel" "$dst" "$trk"
  n_move=$((n_move + 1))
  [ -n "$pat" ] && IGN+=("$pat")
  if [ "$APPLY" -eq 1 ]; then
    mkdir -p "$(dirname "$dst")"
    mv "$rel" "$dst"
    if [ "$trk" = TRACKED ]; then git rm -r --cached --quiet "$rel" >/dev/null 2>&1 || true; fi
  fi
}

echo "Scratch reports:"
for k in qa benchmark canary security deploy; do migrate ".gstack/$k-reports" ".gstack/"; done

echo ""
echo "Session + ship + retro artifacts:"
migrate ".context/claude-session-id"          ".context/claude-session-id" "sessions/claude-session-id"
migrate ".context/codex-session-id"           ".context/codex-session-id"  "sessions/codex-session-id"
migrate ".context/retros"                     ".context/retros/"           "retros"
migrate ".gstack/wip-context-before-squash.md" ".gstack/wip-context-before-squash.md" "ship/wip-context-before-squash.md"

echo ""
echo "ADRs:"
migrate "docs/adr" "docs/adr/"
for a in src/*/docs/adr; do [ -d "$a" ] && migrate "$a" "$a/"; done

echo ""
if [ "$INCLUDE_DOCS" -eq 1 ]; then
  echo "Generated docs (Diataxis-named) — moving (--include-docs):"
  while IFS= read -r f; do migrate "$f" ""; done < <(_diataxis_docs)
else
  cand="$(_diataxis_docs || true)"
  if [ -n "$cand" ]; then
    echo "Generated-doc CANDIDATES (Diataxis-named) — NOT moved. These can be your own"
    echo "hand-written docs. Review, then re-run with --include-docs to move them:"
    printf '%s\n' "$cand" | sed 's/^/  ? /'
  else
    echo "Generated docs (Diataxis-named): (none)"
  fi
fi

left="$( [ -d docs ] && find docs -type f -name '*.md' \
  -not -path 'docs/adr/*' -not -path 'docs/agents/*' \
  -not -name 'tutorial-*' -not -name 'reference-*' -not -name 'howto-*' \
  -not -name 'how-to-*' -not -name 'explanation-*' 2>/dev/null | sort || true )"
if [ -n "$left" ]; then
  echo ""
  echo "LEFT IN REPO (not Diataxis-named — likely hand-written; review manually):"
  printf '%s\n' "$left" | sed 's/^/  /'
fi

if [ "${#IGN[@]}" -gt 0 ] && [ "$IS_GIT" -eq 1 ]; then
  echo ""
  echo ".gitignore:"
  while IFS= read -r pat; do
    if [ -f .gitignore ] && grep -qxF "$pat" .gitignore; then
      printf '  %-20s (already present)\n' "$pat"
    else
      printf '  %-20s (add)\n' "$pat"
      [ "$APPLY" -eq 1 ] && printf '%s\n' "$pat" >> .gitignore
    fi
  done < <(printf '%s\n' "${IGN[@]}" | sort -u)
fi

echo ""
if [ "$APPLY" -eq 1 ]; then
  printf 'Done: %d moved, %d skipped.\n' "$n_move" "$n_skip"
  [ "$INCLUDE_DOCS" -eq 0 ] && echo "(Diataxis-named docs were NOT moved — re-run with --include-docs if those are gstack-generated.)"
  echo "Tracked removals are STAGED — review, then:"
  echo "  git status && git commit -m 'chore: move gstack artifacts to ~/.ai-workspace' && git push"
else
  printf 'Dry-run: %d would move, %d would skip. Re-run with --apply to execute.\n' "$n_move" "$n_skip"
fi
